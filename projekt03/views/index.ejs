<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Notatnik</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
</body>
</html>
<div class="app">
  <header style="display:flex;justify-content:space-between;align-items:center;margin-bottom:18px;">
    <h1>Notatki</h1>
    <div class="controls">
      <a class="btn-secondary" href="/add">Dodaj notatkę</a>
    </div>
  </header>

  <ul>
    <% notes.forEach(n => { %>
      <li>
        <span class="text"><%= n.text %></span>
        <div class="actions">
          <a class="btn-secondary" href="/edit/<%= n.id %>">Edytuj</a>
          <form method="POST" action="/delete/<%= n.id %>" class="inline">
            <button>Usuń</button>
          </form>
        </div>
      </li>
    <% }) %>
  </ul>
</div>
</body>
</html>
