<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Rejestracja</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="app" style="max-width:420px;">
    <header style="margin-bottom:18px;">
      <h1>Rejestracja</h1>
    </header>

    <% if (error) { %>
      <div class="error-box"><%= error %></div>
    <% } %>

    <form method="POST" action="/signup" style="display:grid;gap:10px;">
      <input type="text" name="username" value="<%= user?.username %>" required placeholder="Nazwa użytkownika (min. 3 znaki)" minlength="3" maxlength="25">
      <div class="pas password-field">
        <input type="password" id="password" name="password" required placeholder="Hasło (min. 8 znaków)" minlength="8" maxlength="50">
        <button type="button" id="password-toggle" class="password-toggle" onclick="togglePassword()">Pokaż</button>
      </div>
      <div class="pas password-field">
        <input type="password" id="password_confirm" name="password_confirm" required placeholder="Powtórz hasło" minlength="8" maxlength="50">
        <button type="button" id="password_confirm-toggle" class="password-toggle" onclick="toggleConfirmPassword()">Pokaż</button>
      </div>
      <div style="display:flex;gap:8px;">
        <button class="btn-primary">Zarejestruj</button>
        <a class="btn-secondary" href="/">Powrót</a>
      </div>
    </form>

    <div style="margin-top:14px;font-size:0.9rem;color:#6b7280;">
      Masz już konto? <a href="/login">Zaloguj się</a>
    </div>
  </div>
</body>
<script>
  function togglePassword() {
    var passwordInput = document.getElementById('password');
    var button = document.getElementById('password-toggle');
    if (passwordInput.type == "password"){
      passwordInput.type = "text";
      button.textContent = "Ukryj";
    } else {
      passwordInput.type = "password";
      button.textContent = "Pokaż";
    };
  }
    function toggleConfirmPassword() {
    var passwordInput3 = document.getElementById('password_confirm');
    var button3 = document.getElementById('password_confirm-toggle');
    if (passwordInput3.type == "password"){
      passwordInput3.type = "text";
      button3.textContent = "Ukryj";
    } else {
      passwordInput3.type = "password";
      button3.textContent = "Pokaż";
    };
  }
</script>
</html>
