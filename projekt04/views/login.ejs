<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Logowanie</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="app" style="max-width:420px;">
    <header style="margin-bottom:18px;">
      <h1>Logowanie</h1>
    </header>

    <% if (error) { %>
      <div class="error-box"><%= error %></div>
    <% } %>

    <form method="POST" action="/login?next=<%= encodeURIComponent(next) %>" style="display:grid;gap:10px;">
      <input type="text" name="username" required placeholder="Nazwa użytkownika" minlength="3" maxlength="25">
      <input type="password" name="password" required placeholder="Hasło" minlength="8">
      <div style="display:flex;gap:8px;">
        <button class="btn-primary">Zaloguj</button>
        <a class="btn-secondary" href="/">Powrót</a>
      </div>
    </form>

    <div style="margin-top:14px;font-size:0.9rem;color:#6b7280;">
      Nie masz konta? <a href="/signup">Zarejestruj się</a>
    </div>
  </div>
</body>
</html>
